{
  "name": "paper-trade",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "NODE_ENV=${NODE_ENV:-development} drizzle-kit generate",
    "db:migrate": "NODE_ENV=${NODE_ENV:-development} drizzle-kit migrate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration"
  },
  "dependencies": {
    "@next/env": "^16.2.10",
    "@vercel/functions": "^3.7.5",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "msw": "^2.15.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
