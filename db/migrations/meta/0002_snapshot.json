          "name": "account_activities_type_valid",
          "value": "\"account_activities\".\"type\" in ('starting_cash', 'cash_deposit', 'cash_withdrawal', 'buy_fill', 'sell_fill')"
        },
        "account_activities_required_fields": {
          "name": "account_activities_required_fields",
          "value": "(\n        \"account_activities\".\"type\" in ('starting_cash', 'cash_deposit', 'cash_withdrawal')\n        and \"account_activities\".\"amount_cents\" is not null\n      ) or (\n        \"account_activities\".\"type\" = 'buy_fill'\n        and \"account_activities\".\"ticker\" is not null\n        and \"account_activities\".\"quantity\" is not null\n        and \"account_activities\".\"price_cents\" is not null\n        and \"account_activities\".\"total_cents\" is not null\n        and \"account_activities\".\"quote_timestamp\" is not null\n      ) or (\n        \"account_activities\".\"type\" = 'sell_fill'\n        and \"account_activities\".\"ticker\" is not null\n        and \"account_activities\".\"quantity\" is not null\n        and \"account_activities\".\"price_cents\" is not null\n        and \"account_activities\".\"total_cents\" is not null\n        and \"account_activities\".\"cost_basis_cents\" is not null\n        and \"account_activities\".\"realized_gain_loss_cents\" is not null\n        and \"account_activities\".\"quote_timestamp\" is not null\n      )"
        },
        "account_activities_amount_non_negative": {
          "name": "account_activities_amount_non_negative",
          "value": "\"account_activities\".\"amount_cents\" is null or \"account_activities\".\"amount_cents\" >= 0"
        },
        "account_activities_ticker_canonical": {
          "name": "account_activities_ticker_canonical",
          "value": "\"account_activities\".\"ticker\" is null or (\"account_activities\".\"ticker\" <> '' and \"account_activities\".\"ticker\" = upper(btrim(\"account_activities\".\"ticker\")))"
        },
        "account_activities_quantity_positive": {
          "name": "account_activities_quantity_positive",
          "value": "\"account_activities\".\"quantity\" is null or \"account_activities\".\"quantity\" > 0"
        },
        "account_activities_price_positive": {
